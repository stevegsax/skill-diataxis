<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sites</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { font-size: 16px; }
    body {
      font-family: "Source Serif 4", Georgia, serif;
      color: #1a1a1a;
      background: #fdfdfc;
      line-height: 1.7;
      max-width: 52rem;
      margin: 0 auto;
      padding: 4rem 2rem;
    }
    h1 {
      font-family: "Inter", system-ui, sans-serif;
      font-size: 2rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }
    p.lede {
      color: #6b7280;
      margin-bottom: 2.5rem;
    }
    ul.projects {
      list-style: none;
      display: grid;
      gap: 1.25rem;
    }
    ul.projects li {
      padding: 1.25rem 1.5rem;
      border: 1px solid #e5e7eb;
      border-radius: 0.5rem;
      background: #fff;
      transition: border-color 0.15s ease;
    }
    ul.projects li:hover { border-color: #2563eb; }
    ul.projects a {
      font-family: "Inter", system-ui, sans-serif;
      font-size: 1.15rem;
      font-weight: 600;
      color: #2563eb;
      text-decoration: none;
    }
    ul.projects a:hover { text-decoration: underline; }
    ul.projects .description {
      margin-top: 0.35rem;
      color: #4b5563;
      font-size: 0.95rem;
    }
    .empty {
      color: #6b7280;
      font-style: italic;
    }
  </style>
</head>
<body>
  <h1>Sites</h1>
  <p class="lede">Published documentation projects.</p>
  {% if projects %}
  <ul class="projects">
    {% for project in projects %}
    <li>
      <a href="{{ project.slug }}/index.html">{{ project.name }}</a>
      {% if project.description %}
      <div class="description">{{ project.description }}</div>
      {% endif %}
    </li>
    {% endfor %}
  </ul>
  {% else %}
  <p class="empty">No projects published yet.</p>
  {% endif %}
</body>
</html>
